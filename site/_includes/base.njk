<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{{ title }} — Leaky Abstractions</title>
        {% if summary %}
        <meta name="description" content="{{ summary }}" />
        {% endif %}
        <meta property="og:title" content="{{ title }}" />
        <meta property="og:site_name" content="Leaky Abstractions" />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="{{ siteUrl }}{{ page.url }}" />
        {% if summary %}<meta property="og:description" content="{{ summary }}" />{% endif %}
        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content="{{ title }}" />
        {% if summary %}<meta name="twitter:description" content="{{ summary }}" />{% endif %}
        <link rel="canonical" href="{{ siteUrl }}{{ page.url }}" />
        <link rel="icon" type="image/svg+xml" href="{{ pathPrefix }}/favicon.svg" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
        <link rel="stylesheet" href="{{ pathPrefix }}/css/terminal.css" />
        <link rel="alternate" type="application/atom+xml" title="Leaky Abstractions" href="{{ pathPrefix }}/feed.xml" />
        <script defer src="https://cloud.umami.is/script.js" data-website-id="54bb7844-a369-4bf4-9771-0f3da70999a0"></script>
        <script>
            (function() {
                var saved = localStorage.getItem('theme');
                if (saved) {
                    try {
                        var colors = JSON.parse(saved);
                        var root = document.documentElement;
                        Object.keys(colors).forEach(function(key) {
                            root.style.setProperty('--' + key, colors[key]);
                        });
                    } catch(e) {}
                } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) {
                    var light = {"base00":"#fdf6e3","base01":"#eee8d5","base02":"#93a1a1","base03":"#839496","base04":"#657b83","base05":"#586e75","base06":"#073642","base07":"#002b36","base08":"#dc322f","base09":"#cb4b16","base0A":"#b58900","base0B":"#859900","base0C":"#2aa198","base0D":"#268bd2","base0E":"#6c71c4","base0F":"#d33682"};
                    var root = document.documentElement;
                    Object.keys(light).forEach(function(key) {
                        root.style.setProperty('--' + key, light[key]);
                    });
                    localStorage.setItem('theme', JSON.stringify(light));
                }
            })();
        </script>
    </head>
    <body>
        <script>
            var FILETREE = {{ filetree | dump | safe }};
            var CURRENT_PATH = {{ virtualPath | dump | safe }};
            var PATH_PREFIX = {{ pathPrefix | dump | safe }};
        </script>
        <div class="terminal">
            <div class="terminal-chrome">
                <div class="dots">
                    <div class="dot dot-red"></div>
                    <div class="dot dot-yellow"></div>
                    <div class="dot dot-green"></div>
                </div>
                <span class="title" id="breadcrumbs"></span>
                <div style="display: flex; align-items: center; gap: 4px; margin-left: auto;">
                    <button class="search-trigger" id="search-btn" aria-label="Search" title="Search">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <span class="search-shortcut" id="search-shortcut"></span>
                    </button>
                    <a href="https://github.com/leaky-abstractions/content" class="chrome-icon desktop-only" aria-label="GitHub" title="GitHub" target="_blank" rel="noopener">
                        <i class="fa-brands fa-github"></i>
                    </a>
                    <a href="https://youtube.com/@leakyabstractions" class="chrome-icon desktop-only" aria-label="YouTube" title="YouTube" target="_blank" rel="noopener">
                        <i class="fa-brands fa-youtube"></i>
                    </a>
                    <a href="{{ pathPrefix }}/feed.xml" class="chrome-icon desktop-only" aria-label="RSS feed" title="RSS feed">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="6.18" cy="17.82" r="2.18"/><path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/></svg>
                    </a>
                    <div style="position: relative;">
                        <button class="theme-toggle" onclick="toggleThemePicker()" aria-label="Change theme">&#9881;</button>
                        <div class="theme-picker" id="theme-picker"></div>
                    </div>
                </div>
                <div class="reading-progress" id="reading-progress"></div>
            </div>
            <div class="terminal-body">
                {% if page.inputPath and "episodes/" in page.inputPath and "blog.md" in page.inputPath %}
                {% set episodeSlug = page.inputPath | replace("./", "") | replace("/blog.md", "") | replace("episodes/_series/", "") | replace("episodes/", "") %}
                {% set catSlug = episodeSlug.split("/") | last %}
                {% set vDir = virtualPath.replace("/" + catSlug + ".md", "") %}
                {% set parentUrl = vDir | replace("~", "") | default("/") %}
                {% if parentUrl != "/" %}{% set parentUrl = parentUrl + "/" %}{% endif %}
                {% set parentUrl = pathPrefix + parentUrl %}
                {% from "macros.njk" import catSection, frontmatterBlock, backLink %}
                {% from "post-card.njk" import postCard %}
                {% call catSection(vDir, catSlug + '.md', { pagefind: true, body: 'post-content' }) -%}
                {{ frontmatterBlock(date=page.date | date, readingTime=readingTime, tags=tags, series=seriesProgress) }}
                {{ content | safe }}
                {%- endcall %}
                {% if seriesNav and (seriesNav.prev or seriesNav.next) %}
                <div class="section">
                    <div class="prompt"><span class="path">{{ vDir }}</span> <span class="dollar">$</span> ls{% if seriesNav.prev %} {{ seriesNav.prev.slug }}.md{% endif %}{% if seriesNav.next %} {{ seriesNav.next.slug }}.md{% endif %} <span class="prompt-comment"># continue the series</span></div>
                    {% if seriesNav.prev %}
                    {{ postCard({
                        kind: 'post',
                        url: seriesNav.prev.url,
                        title: seriesNav.prev.title,
                        date: seriesNav.prev.date,
                        readingTime: seriesNav.prev.readingTime,
                        summary: seriesNav.prev.summary,
                        tags: seriesNav.prev.tags,
                        seriesPosition: 'prev · ' + seriesNav.prev.seriesPosition
                    }) }}
                    {% endif %}
                    {% if seriesNav.next %}
                    {{ postCard({
                        kind: 'post',
                        url: seriesNav.next.url,
                        title: seriesNav.next.title,
                        date: seriesNav.next.date,
                        readingTime: seriesNav.next.readingTime,
                        summary: seriesNav.next.summary,
                        tags: seriesNav.next.tags,
                        seriesPosition: 'next · ' + seriesNav.next.seriesPosition
                    }) }}
                    {% endif %}
                </div>
                {% endif %}
                {% if relatedEpisodes and relatedEpisodes.items.length %}
                <div class="section">
                    <div class="prompt"><span class="path">{{ vDir }}</span> <span class="dollar">$</span> {% if relatedEpisodes.isFallback %}ls -lt ~/episodes | head -3{% else %}grep -rlE "({{ relatedEpisodes.searchTags | join('|') }})" ~/episodes{% endif %} <span class="prompt-comment"># {% if relatedEpisodes.isFallback %}more episodes{% else %}related episodes{% endif %}</span></div>
                    {% for ep in relatedEpisodes.items %}
                    {{ postCard({
                        kind: 'post',
                        url: ep.url,
                        title: ep.title,
                        date: ep.date,
                        readingTime: ep.readingTime,
                        summary: ep.summary,
                        tags: ep.tags,
                        seriesPosition: ep.seriesPosition
                    }) }}
                    {% endfor %}
                </div>
                {% endif %}
                {{ backLink(parentUrl, 'ls -lt') }}
                {% else %}
                {{ content | safe }}
                {% endif %}

                <div class="input-line">
                    <span class="prompt-prefix"><span class="path" id="prompt-path"></span> <span class="dollar">$</span></span>
                    <div class="input-wrap">
                        <input type="text" id="shell-input" aria-label="Terminal input" autocomplete="off" spellcheck="false" />
                        <span class="cursor" id="shell-cursor"></span>
                        <span class="autocomplete-hint" id="shell-hint"></span>
                    </div>
                </div>
                <div id="shell-output"></div>
                <div class="toc-container" id="toc-container" style="display: none;">
                    <button class="toc-toggle" id="toc-toggle" aria-label="Table of contents" title="Table of contents">#</button>
                    <div class="toc-panel" id="toc-panel">
                        <div class="toc-header">
                            <span class="toc-title">Table of Contents</span>
                            <button class="toc-close" id="toc-close" aria-label="Close">&times;</button>
                        </div>
                        <nav class="toc-list" id="toc-list"></nav>
                    </div>
                </div>
            </div>
        </div>
        <div class="search-overlay" id="search-overlay">
            <div class="search-modal">
                <div class="search-input-line">
                    <span class="prompt-prefix"><span class="path">~</span> <span class="dollar">$</span> grep</span>
                    <input type="text" id="search-input" placeholder="search..." autocomplete="off" spellcheck="false" />
                </div>
                <div class="search-results" id="search-results"></div>
            </div>
        </div>
        <script src="{{ pathPrefix }}/js/interaction.js"></script>
        <script src="{{ pathPrefix }}/js/themes.js"></script>
        <script src="{{ pathPrefix }}/js/shell.js"></script>
    </body>
</html>
