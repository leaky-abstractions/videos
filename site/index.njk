---
title: Home
permalink: /index.html
virtualPath: "~"
---

<div class="section">
    <div class="prompt"><span class="path">~</span> <span class="dollar">$</span> cat welcome.md</div>
    <div class="welcome">{{ welcome | md | safe }}</div>
</div>

<div class="section">
    <div class="prompt"><span class="path">~</span> <span class="dollar">$</span> ls -lt episodes/</div>
    {% for post in collections.standaloneEpisodes %}
    <div class="post">
        <div class="post-title">
            <a href="{{ post.url }}"><i class="fa-brands fa-markdown"></i> <span class="link-text">{{ post.data.title }}</span></a>
        </div>
        <div class="post-meta">
            <span class="date">{{ post.date | date }}</span> — {{ post.data.summary }}{% for tag in post.data.tags %}<span class="tag">{{ tag }}</span>{% endfor %}
        </div>
    </div>
    {% endfor %}
    {% for series in allSeriesData %}
    <div class="post series">
        <div class="post-title">
            <a href="{{ pathPrefix }}/episodes/{{ series.slug }}/"><i class="fa-solid fa-folder"></i> <span class="link-text">{{ series.slug }}/</span></a>
        </div>
        <div class="post-meta">
            {% if series.episodes.length %}<span class="date">{{ series.episodes[series.episodes.length - 1].date }}</span> — {% endif %}{{ series.description }} <span class="tag tag-count">{{ series.episodes.length }} episode{% if series.episodes.length != 1 %}s{% endif %}</span>
        </div>
    </div>
    {% endfor %}
</div>

<div class="section">
    <div class="prompt"><span class="path">~</span> <span class="dollar">$</span> ls links/</div>
    <div class="ls-output">
        {% for link in links %}
        <a href="{{ link.url }}" class="ls-entry ls-type-{{ link.type | default('file') }}{% if link.external %} ls-external{% endif %}"{% if link.external %} target="_blank" rel="noopener"{% endif %}>{% if link.icon %}<i class="{{ link.icon }}"></i> {% endif %}<span class="link-text">{{ link.name }}</span></a>
        {% endfor %}
    </div>
</div>
