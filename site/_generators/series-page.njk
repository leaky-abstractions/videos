---
pagination:
    data: allSeriesData
    size: 1
    alias: seriesData
permalink: "/episodes/{{ seriesData.slug }}/index.html"
layout: base.njk
eleventyComputed:
    title: "{{ seriesData.title }}"
    summary: "{{ seriesData.description }}"
    virtualPath: "~/episodes/{{ seriesData.slug }}"
---
{% from "post-card.njk" import postCard %}
{% from "macros.njk" import catSection, backLink %}

{% call catSection('~/episodes/' + seriesData.slug, 'README.md') %}{{ seriesData.readme | md | safe }}{% endcall %}

<div class="section">
    <div class="prompt"><span class="path">~/episodes/{{ seriesData.slug }}</span> <span class="dollar">$</span> ls -lt</div>
    {% if seriesData.episodes.length %}
    {% for ep in seriesData.episodes %}
    {{ postCard({
        kind: 'post',
        url: ep.url,
        title: ep.title,
        date: ep.date,
        readingTime: ep.readingTime,
        summary: ep.summary,
        tags: ep.tags,
        seriesPosition: ep.seriesPosition
    }) }}
    {% endfor %}
    {% else %}
    <p>No episodes yet.</p>
    {% endif %}
</div>
{{ backLink(pathPrefix + '/episodes/') }}
